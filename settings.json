{
  "breadcrumbs.enabled": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.cursorBlinking": "solid",
  "editor.cursorStyle": "line",
  "editor.cursorWidth": 5,
  "editor.fontFamily": "'Courier Prime', 'Courier New', Monaco, monospace",
  "editor.fontSize": 15,
  "editor.fontWeight": "400",
  "editor.formatOnSave": true,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "all",
  "editor.suggestSelection": "first",
  "files.associations": {
    "*.html": "html"
  },
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true,
    "**/build": true
  },
  "files.insertFinalNewline": true,
  "prettier.disableLanguages": ["django-html"],
  "python.defaultInterpreterPath": "/Users/klaus/.pyenv/versions/3.8.2/bin/python",
  "python.languageServer": "Microsoft",
  "python.linting.flake8Enabled": true,
  "python.linting.mypyEnabled": true,
  "python.venvFolders": ["/Users/klaus/.local/share/virtualenvs/"],
  "sync.forceUpload": true,
  "sync.gist": "bbfedf13dccde3a103f21abcb57de94b",
  "terminal.integrated.fontFamily": "'Droid Sans Mono for Powerline', Monaco, 'Courier New', monospace",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.shell.osx": "/bin/zsh",
  "vim.easymotion": true,
  "vim.leader": ",",
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "window.title": "${activeEditorLong}${separator}${rootName}",
  "window.zoomLevel": 0,
  "workbench.colorTheme": "Dracula",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.sideBar.location": "left",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  }
}
